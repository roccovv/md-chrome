{
  "manifest_version": 3,
  "name": "萌多工具",
  "version": "1.0.0",
  "description": "一个现代化的浏览器首页导航插件，支持自定义壁纸、搜索和快捷工具",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "bookmarks"
  ],
  "host_permissions": [
    "https://devapi.qweather.com/*",
    "https://api.qweather.com/*",
    "https://geoapi.qweather.com/*",
    "https://*.qweatherapi.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
